# ============================================
# Gemini Business2API environment example
# ============================================

# Required: admin password used to log in to the web admin panel.
ADMIN_KEY=your-admin-secret-key

# Optional: host port for the main 2API service.
# PORT=7860

# Optional: main service base URL override.
# BASE_URL=http://localhost:7860

# ============================================
# Storage
# ============================================

# Recommended for multi-machine deployments or when the refresh worker
# runs outside this compose project. Leave empty to use local SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: override SQLite path. By default the main service uses data/data.db.
# SQLITE_PATH=./data/data.db

# ============================================
# Optional refresh worker image/service
# Start with:
# docker compose --profile refresh up -d
# ============================================

# Optional: Docker image for the standalone refresh worker.
# REFRESH_WORKER_IMAGE=cooooookk/gemini-refresh-worker:latest

# Optional: worker health endpoint port exposed on the host.
# REFRESH_HEALTH_PORT=8080

# Optional: force enable/disable scheduled refresh regardless of panel setting.
# FORCE_REFRESH_ENABLED=true

# Optional: worker-side overrides. When left empty, the worker reads the
# shared values from the admin settings page.
# REFRESH_INTERVAL_MINUTES=30
# REFRESH_WINDOW_HOURS=1
# BROWSER_HEADLESS=true
# PROXY_FOR_AUTH=socks5h://127.0.0.1:7890

# ============================================
# Where each kind of config lives
# ============================================

# 1) Admin panel -> System Settings
#    Shared 2API settings and shared refresh/email defaults live there.
#
# 2) Admin panel -> Accounts
#    Per-account import/export fields live there, including:
#    mail_provider, mail_address, mail_password, mail_client_id,
#    mail_refresh_token, mail_base_url, mail_api_key, mail_jwt_token,
#    mail_verify_ssl, mail_domain and related account-specific fields.
#
# 3) Worker environment variables
#    Only use these when the refresh worker needs machine-local overrides.
